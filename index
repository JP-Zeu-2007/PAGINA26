    <div id="mensajeEvaluacion" style="margin-top: 20px; padding: 20px; background: #fffcf0; border-radius: 30px;">
      <span id="textoResultado">Esperando documento...</span>
      <div id="detallesError" style="margin-top: 10px;"></div>
    </div>
  </div>
</div>

<!-- VENTANA DE FELICITACIONES -->
<div class="felicitaciones-fullscreen" id="ventanaFelicitaciones">
  <svg class="hoja-decorativa hoja1" viewBox="0 0 200 200" fill="#2d8c4e">
    <path d="M100,10 C130,10 170,40 180,80 C190,120 160,160 120,180 C100,190 80,180 70,160 C60,140 50,100 70,60 C80,30 90,10 100,10Z"/>
