    <div class="zona-upload">
      <label><i class="fas fa-cloud-upload-alt"></i> Subir documento Word (.docx):</label>
      <input type="file" id="uploadDoc" accept=".docx" style="padding: 12px; width: 100%;">
      <p style="margin-top: 8px;"><i class="fas fa-sync-alt"></i> Intentos ilimitados</p>
