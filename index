<script>
  (function(){
    "use strict";

    const pantallaInicio = document.getElementById('pantallaInicio');
    const modalLogin = document.getElementById('modalLogin');
    const appEjercicio = document.getElementById('appEjercicio');
    const btnEntrar = document.getElementById('btnEntrarJungla');
    const btnAceptarLogin = document.getElementById('btnAceptarLogin');
    const nombreInput = document.getElementById('nombreEstudiante');
    const gradoInput = document.getElementById('gradoEstudiante');
    const uploadInput = document.getElementById('uploadDoc');
    const textoResultado = document.getElementById('textoResultado');
    const detallesError = document.getElementById('detallesError');
    const zonaCarga = document.getElementById('zonaCargaSimulada');
    const barraProgreso = document.getElementById('barraProgresoFalsa');
    const msgCodigo = document.getElementById('mensajeCodigoSimulado');
    const ventanaFelicitaciones = document.getElementById('ventanaFelicitaciones');
    const felizNombreGrado = document.getElementById('felizNombreGrado');
    const btnCerrarFeliz = document.getElementById('btnCerrarFelicitaciones');

    let nombreGuardado = '', gradoGuardado = '';

    btnEntrar.addEventListener('click', ()=> modalLogin.style.display = 'flex');
    
    btnAceptarLogin.addEventListener('click', ()=>{
      const n = nombreInput.value.trim(); const g = gradoInput.value.trim();
      if(!n||!g) { alert('Completa todos los campos'); return; }
      nombreGuardado = n; gradoGuardado = g;
      modalLogin.style.display = 'none';
      pantallaInicio.style.display = 'none';
      appEjercicio.style.display = 'block';
      iniciarBarraFalsa();
    });

    function iniciarBarraFalsa(){
      zonaCarga.style.display = 'block';
      barraProgreso.style.width = '0%';
      let prog = 0;
      const frases = ["> Cargando módulo selvático...", "> Conectando a NSC://jungla...", "> Desencriptando lianas...", "> ¡Acceso concedido!"];
      const intv = setInterval(()=>{
        prog += 12;
        if(prog>=100){ 
          prog=100; 
          barraProgreso.style.width='100%'; 
          barraProgreso.style.background='#2ecc71'; 
          msgCodigo.innerHTML='> LISTO PARA RECIBIR DOCUMENTOS.'; 
          clearInterval(intv); 
          setTimeout(()=>zonaCarga.style.display='none',1000); 
        } else { 
          barraProgreso.style.width=prog+'%'; 
          msgCodigo.innerHTML = frases[Math.floor(prog/30)] + ` (${prog}%)`; 
        }
      },150);
    }

    function esColorRojo(colorVal) {
      if(!colorVal) return false;
      const color = colorVal.toUpperCase().trim();
      const rojosConocidos = ['FF0000', 'RED', 'ROJO', 'C0504D', 'C00000', 'E60000', 'CC0000', 'FF3333', 'FF6666'];
      if(rojosConocidos.includes(color)) return true;
      if(color.length === 6 && /^[0-9A-F]{6}$/.test(color)) {
        const r = parseInt(color.substr(0,2), 16);
        const g = parseInt(color.substr(2,2), 16);
        const b = parseInt(color.substr(4,2), 16);
        return (r > 120 && r > g * 1.3 && r > b * 1.3);
      }
      return false;
    }

    function extraerEstilosDeRun(rPr) {
      let tamano = null, colorVal = null, fuente = null;
      if(!rPr) return { tamano, colorVal, fuente };
      
      const sz = rPr.getElementsByTagNameNS("*", "sz")[0] || rPr.getElementsByTagNameNS("*", "szCs")[0];
      if(sz) { const val = sz.getAttributeNS("*", "val") || sz.getAttribute("w:val") || sz.getAttribute("val"); if(val) tamano = parseInt(val) / 2; }
      
      const color = rPr.getElementsByTagNameNS("*", "color")[0];
      if(color) colorVal = color.getAttributeNS("*", "val") || color.getAttribute("w:val") || color.getAttribute("val");
      
      const rFonts = rPr.getElementsByTagNameNS("*", "rFonts")[0];
      if(rFonts) fuente = rFonts.getAttributeNS("*", "ascii") || rFonts.getAttribute("w:ascii") || rFonts.getAttributeNS("*", "hAnsi");
      
      return { tamano, colorVal, fuente };
    }

    async function evaluarDocumentoCompleto(file) {
      textoResultado.innerHTML = '🔬 Analizando documento...';
      detallesError.innerHTML = '';
      const errores = [];
      
      const nombreArchivo = file.name;
      const nombreSinExt = nombreArchivo.replace(/\.docx$/i, '');
      const patronNombre = /(sexto\s*primaria|6to\.?\s*primaria)/i;
      if(!nombreArchivo.toLowerCase().endsWith('.docx')) errores.push('❌ El archivo debe ser .docx');
      if(!patronNombre.test(nombreSinExt)) errores.push('❌ El nombre debe incluir "Sexto Primaria" o "6to Primaria".');

      try {
        const zip = await JSZip.loadAsync(file);
        const documentXml = await zip.file("word/document.xml").async("text");
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(documentXml, "application/xml");
        
        const arrayBuffer = await file.arrayBuffer();
        const textResult = await mammoth.extractRawText({ arrayBuffer: arrayBuffer });
        const textoPlano = textResult.value;
        const lineas = textoPlano.split('\n').filter(l => l.trim().length > 0);
        const primeraLineaTexto = lineas.length > 0 ? lineas[0].trim() : '';
        
        const allParagraphs = xmlDoc.getElementsByTagNameNS("*", "p");
        
        let tituloTamanoOk = false, tituloColorOk = false;
        let errorFuente = false, errorTamanioContenido = false, errorColorContenido = false;
        let esPrimerParrafoConTexto = true;
        
        if(!/cadena\s+alimenticia/i.test(primeraLineaTexto)) {
          errores.push('❌ La PRIMERA LÍNEA debe contener "cadena alimenticia".');
        }
        
        for(let p of allParagraphs) {
          const textos = p.getElementsByTagNameNS("*", "t");
          let textoParrafo = ''; for(let t of textos) textoParrafo += t.textContent;
          if(textoParrafo.trim().length === 0) continue;
          
          const esTitulo = esPrimerParrafoConTexto;
          if(esTitulo) {
            esPrimerParrafoConTexto = false;
            const runs = p.getElementsByTagNameNS("*", "r");
            for(let run of runs) {
              const rPr = run.getElementsByTagNameNS("*", "rPr")[0];
              const estilos = extraerEstilosDeRun(rPr);
              if(estilos.tamano === 16) tituloTamanoOk = true;
              if(esColorRojo(estilos.colorVal)) tituloColorOk = true;
              if(estilos.fuente && !estilos.fuente.toLowerCase().includes('times new roman')) errorFuente = true;
            }
          } else {
            const runs = p.getElementsByTagNameNS("*", "r");
            for(let run of runs) {
              const rPr = run.getElementsByTagNameNS("*", "rPr")[0];
              const estilos = extraerEstilosDeRun(rPr);
              const textoRun = run.getElementsByTagNameNS("*", "t")[0]?.textContent || '';
              if(textoRun.trim().length === 0) continue;
              
              if(estilos.tamano && estilos.tamano !== 12) errorTamanioContenido = true;
              const color = estilos.colorVal;
              const esNegro = !color || color === '000000' || color === 'auto' || color === 'black' || color === '0' || color === 'FFFFFF';
              if(!esNegro && !esColorRojo(color)) errorColorContenido = true;
              if(estilos.fuente && !estilos.fuente.toLowerCase().includes('times new roman')) errorFuente = true;
            }
          }
        }
        
        if(!tituloTamanoOk) errores.push('⚠️ El título debe tener tamaño 16.');
        if(!tituloColorOk) errores.push('⚠️ El título debe ser de color ROJO.');
        if(errorFuente) errores.push('⚠️ Todo el documento debe usar fuente "Times New Roman".');
        if(errorTamanioContenido) errores.push('⚠️ El contenido debe tener tamaño 12.');
        if(errorColorContenido) errores.push('⚠️ El contenido debe ser de color NEGRO.');
        
        if(!/cadena\s+alimenticia/i.test(textoPlano)) errores.push('⚠️ El documento debe explicar qué es la cadena alimenticia.');
        if(!/(depredador|predador)/i.test(textoPlano) || !/presa/i.test(textoPlano)) errores.push('⚠️ Falta información sobre depredador y presa.');
        if(!textoPlano.includes('Documento de Laboratorio NSC')) errores.push('❌ Falta el texto final "Documento de Laboratorio NSC".');
        
        if(errores.length === 0) {
          textoResultado.innerHTML = '';
          detallesError.innerHTML = '';
          felizNombreGrado.innerHTML = `${nombreGuardado} · ${gradoGuardado}`;
          ventanaFelicitaciones.style.display = 'flex';
        } else {
          textoResultado.innerHTML = '<span class="brillante-error">❌ DOCUMENTO INVÁLIDO ❌</span>';
          let lista = '<ul style="color:#a00; text-align:left;">';
          errores.forEach(e => lista += `<li>${e}</li>`);
          lista += '</ul><p><i class="fas fa-sync-alt"></i> Corrige y vuelve a subir.</p>';
          detallesError.innerHTML = lista;
          uploadInput.value = '';
        }
      } catch (err) {
        textoResultado.innerHTML = '⚠️ Error al procesar el documento.';
        console.error(err);
      }
    }

    uploadInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if(file) evaluarDocumentoCompleto(file);
    });

    btnCerrarFeliz.addEventListener('click', ()=>{
      ventanaFelicitaciones.style.display = 'none';
      uploadInput.value = '';
      textoResultado.innerHTML = 'Esperando documento...';
      detallesError.innerHTML = '';
    });

    modalLogin.addEventListener('click', (e)=> { if(e.target === modalLogin) modalLogin.style.display = 'none'; });
  })();
</script>
</body>
</html>
