<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🌿 NSC · Laboratorio Sexto Primaria 🌿</title>
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.4.2/mammoth.browser.min.js"></script>
  <script src="https://unpkg.com/jszip/dist/jszip.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Quicksand', sans-serif; overflow-x: hidden; background: #0b2f1f; }
    
    /* ========== PANTALLA INICIO JUNGLA ========== */
    .jungla-portada {
      position: relative; width: 100%; min-height: 100vh;
      background: radial-gradient(circle at 30% 40%, #1d5e3f, #0a2e1b);
      overflow: hidden; display: flex; flex-direction: column;
      align-items: center; justify-content: center; perspective: 8px;
    }
    .parallax-layer { position: absolute; top: 0; left: 0; width: 100%; height: 120%; pointer-events: none; }
    .nubes {
      position: absolute; width: 100%; height: 100%;
      background: repeating-radial-gradient(circle at 20% 30%, rgba(255,255,240,0.2) 0%, transparent 18%);
      filter: blur(12px); transform: translateZ(-3px) scale(1.8);
      animation: moverNubes 38s infinite alternate ease-in-out;
    }
    .hojas-trop {
      position: absolute; width: 100%; height: 100%;
      background-image: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" viewBox="0 0 1200 800" xmlns="http://www.w3.org/2000/svg"><path d="M150,150 Q200,40 280,100 Q220,160 150,150" fill="%23307a3e" opacity="0.6"/><path d="M800,600 Q880,520 950,610 Q880,680 800,600" fill="%232d8c4e" opacity="0.5"/><path d="M100,600 Q180,510 260,590 Q170,680 100,600" fill="%231e6b37" opacity="0.7"/><path d="M1050,150 Q1120,40 1180,120 Q1090,180 1050,150" fill="%233c9e5a" opacity="0.5"/></svg>');
      background-size: cover; transform: translateZ(-1.5px) scale(1.25);
      animation: flotarHojas 12s infinite alternate;
    }
    .hojas-delante {
      position: absolute; bottom: 0; left: 0; width: 100%; height: 180px;
      background: url('data:image/svg+xml;utf8,<svg width="100%" height="180" viewBox="0 0 1200 180" xmlns="http://www.w3.org/2000/svg"><path d="M0,180 Q100,90 200,130 Q350,40 500,110 Q650,30 800,120 Q950,40 1100,140 L1200,90 L1200,180 Z" fill="%23164f2b" opacity="0.9"/><path d="M-20,180 Q120,120 280,150 Q420,70 600,140 Q750,60 950,130 Q1080,70 1220,120 L1220,180 Z" fill="%230e3d22" opacity="0.8"/></svg>');
      background-size: cover; transform: translateZ(0px);
    }
    @keyframes moverNubes { 0% { transform: translateZ(-3px) scale(1.8) translateX(-3%); } 100% { transform: translateZ(-3px) scale(1.8) translateX(5%); } }
    @keyframes flotarHojas { 0% { transform: translateZ(-1.5px) scale(1.25) rotate(0deg); } 100% { transform: translateZ(-1.5px) scale(1.25) rotate(1.5deg); } }
    
    .contenido-portada {
      position: relative; z-index: 10; text-align: center; color: #f9f7e8;
      text-shadow: 6px 6px 12px #0a1f0e; padding: 1.5rem;
      background: rgba(10, 40, 18, 0.3); backdrop-filter: blur(5px);
      border-radius: 60px 20px 60px 20px; border: 2px solid #c0e084;
      box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }
    h1 { font-size: 5.5rem; font-weight: 700; letter-spacing: 6px; }
    .subtitulo-jungla { font-size: 1.8rem; margin: 10px 0 30px; background: #1e4a2c; display: inline-block; padding: 8px 32px; border-radius: 50px; }
    .btn-entrar {
      background: #fedb5f; border: none; padding: 20px 60px; font-size: 2.2rem; font-weight: bold;
      color: #173e1f; border-radius: 80px; box-shadow: 0 15px 0 #7b4f1a, 0 8px 20px black;
      cursor: pointer; transition: 0.08s; border: 3px solid #fef9ae; text-transform: uppercase;
    }
    .btn-entrar:active { transform: translateY(10px); box-shadow: 0 5px 0 #7b4f1a, 0 8px 20px black; }
    
    /* ========== MODAL LOGIN ========== */
    .modal-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,20,5,0.8); backdrop-filter: blur(6px);
      display: none; justify-content: center; align-items: center; z-index: 100;
    }
    .modal-card {
      background: #f5fbe8; padding: 30px 40px; border-radius: 48px 16px 48px 16px;
      box-shadow: 0 30px 40px #0f2b0c; width: 450px; max-width: 90%;
      text-align: center;
    }
    
    /* LOGO EN MODAL */
    .logo-modal {
      width: 200px; margin-bottom: 20px; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
    }
    
    .input-selva { width: 100%; padding: 14px; margin: 10px 0; border-radius: 40px; border: 3px solid #58853e; background: #fefee4; }
    .btn-aceptar { background: #2b7433; border: none; color: white; font-weight: bold; padding: 14px; font-size: 1.3rem; border-radius: 40px; width: 100%; cursor: pointer; }
    
    /* ========== APP PRINCIPAL ========== */
    .app-principal { display: none; min-height: 100vh; background: #d9e6cf; background-image: radial-gradient(circle at 10% 20%, #e2f0d6, #bcd0aa); padding: 20px; }
    .contenido-ejercicio {
      max-width: 1300px; margin: 0 auto; background: rgba(253, 255, 240, 0.85);
      backdrop-filter: blur(12px); padding: 30px; border-radius: 60px 20px;
      border: 2px solid #9bc181;
    }
    
    /* LOGO EN APP PRINCIPAL */
    .logo-app {
      display: block; margin: 0 auto 20px; width: 250px;
      filter: drop-shadow(0 6px 12px rgba(0,30,0,0.3));
    }
    
    .brillante-error { color: #ff1a1a; text-shadow: 0 0 12px #ff9090; font-weight: bold; font-size: 1.8rem; }
    .barra-fondo { height: 36px; background: #c2d6b2; border-radius: 40px; }
    .barra-llena { height: 100%; width: 0%; background: #d44; border-radius: 40px; transition: width 0.15s; }
    .zona-upload { background: #e6f2db; padding: 20px; border-radius: 30px; border: 3px dashed #3f6e31; }
    .lista-chequeo { background: #edffe3; padding: 24px; border-radius: 40px; margin: 20px 0; }

    /* ========== VENTANA DE FELICITACIONES ========== */
    .felicitaciones-fullscreen {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: linear-gradient(145deg, #0a3d1f 0%, #1a6e3a 50%, #2d8c4e 100%);
      z-index: 1000; display: none; justify-content: center; align-items: center;
      overflow: hidden;
    }
    
    .hoja-decorativa {
      position: absolute; pointer-events: none; opacity: 0.85;
      animation: mecerHoja 4s infinite ease-in-out alternate;
    }
    
    @keyframes mecerHoja {
      0% { transform: rotate(-5deg) translateX(0); }
      100% { transform: rotate(8deg) translateX(15px); }
    }
    
    .hoja1 { top: 5%; left: 2%; width: 180px; animation-duration: 3.5s; }
    .hoja2 { top: 15%; right: 3%; width: 220px; animation-duration: 4.2s; animation-delay: 0.5s; }
    .hoja3 { bottom: 10%; left: 5%; width: 200px; animation-duration: 3.8s; animation-delay: 1s; }
    .hoja4 { bottom: 5%; right: 8%; width: 250px; animation-duration: 4.5s; }
    .hoja5 { top: 40%; left: -20px; width: 160px; animation-duration: 3s; }
    .hoja6 { top: 60%; right: -30px; width: 190px; animation-duration: 5s; animation-delay: 0.8s; }
    .hoja7 { top: 30%; left: 15%; width: 130px; animation-duration: 3.3s; animation-delay: 0.3s; }
    .hoja8 { bottom: 30%; right: 15%; width: 170px; animation-duration: 4s; animation-delay: 1.2s; }
    
    .contenido-felicitacion {
      position: relative; z-index: 10; text-align: center; color: #f9f7e8;
      text-shadow: 4px 4px 12px #0a1f0e; padding: 3rem;
      background: rgba(20, 60, 25, 0.5); backdrop-filter: blur(16px);
      border-radius: 80px 20px 80px 20px; border: 4px solid #fdd835;
      box-shadow: 0 30px 60px rgba(0,0,0,0.6), inset 0 0 40px rgba(255,255,200,0.3);
      max-width: 800px; margin: 20px;
      animation: aparecer 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    @keyframes aparecer {
      0% { transform: scale(0.2) rotate(-10deg); opacity: 0; }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }
    
    .contenido-felicitacion h2 {
      font-size: 5rem; font-weight: 700; margin-bottom: 20px;
      background: linear-gradient(45deg, #ffd700, #fff8b0);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      text-shadow: none;
    }
    
    .nombre-grado-feliz {
      font-size: 3.5rem; background: #1e4a2c; display: inline-block;
      padding: 15px 50px; border-radius: 60px; margin: 20px 0;
      box-shadow: inset 0 -3px 0 #a2d679, 0 15px 20px rgba(0,0,0,0.3);
    }
    
    .puntuacion-gigante {
      font-size: 6rem; font-weight: 800; color: #ffeb3b;
      text-shadow: 6px 6px 0 #2e7d32;
      margin: 20px 0;
    }
    
    .btn-cerrar-feliz {
      background: #fedb5f; border: none; padding: 18px 50px; font-size: 1.8rem;
      font-weight: bold; color: #173e1f; border-radius: 60px;
      box-shadow: 0 10px 0 #7b4f1a; cursor: pointer; margin-top: 30px;
      transition: 0.05s; border: 3px solid #fef9ae;
    }
    
    .btn-cerrar-feliz:active { transform: translateY(6px); box-shadow: 0 4px 0 #7b4f1a; }
  </style>
</head>
<body>

<!-- PANTALLA INICIO -->
<div class="jungla-portada" id="pantallaInicio">
